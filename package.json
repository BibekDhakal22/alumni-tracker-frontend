{
  "name": "alumni-tracker",
  "private": true,
  "version": "1.0.0",
  "description": "Alumni Tracking System - BCA Final Year Project",
  "author": "Bibek Sharma",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "NODE_ENV=development electron .",
    "electron:win": "set NODE_ENV=development && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && set NODE_ENV=development && electron .\"",
    "electron:build": "npm run build && electron-builder build --win"
  },
  "build": {
    "appId": "com.alumnitracker.app",
    "productName": "Alumni Tracker",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "postcss": "^8.4.35",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.2",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "wait-on": "^8.0.3"
  }
}